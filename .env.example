# --- Telegram bot ---
# 0 = бот включен, 1 = бот выключен (web-only режим)
BOT_DISABLED=0

# Обязателен, если BOT_DISABLED=0
BOT_TOKEN=1234567890:AAEXAMPLE_BOT_TOKEN

# Обязателен, если BOT_DISABLED=0
SUPERADMIN_TELEGRAM_ID=123456789

# --- Database ---
DB_PATH=juri_bot.sqlite3

# --- Sessions ---
SESSION_TTL_SECONDS=1800

# --- Web ---
WEB_ENABLED=0
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_DIR=/root/juri-bot/web
WEB_RESULTS_PATH=/root/juri-bot/web/results.json

# Коды жюри для web-only входа, через запятую
WEB_JURY_CODES=

# --- Logging ---
# Telegram channel id, optional
LOG_CHANNEL_ID=

# --- Bot mode ---
# polling | webhook
BOT_MODE=polling

# --- Webhook (used only when BOT_MODE=webhook) ---
WEBHOOK_URL=https://example.com:8443/webhook
WEBHOOK_PATH=/webhook
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_CERT=/path/to/fullchain.pem
WEBHOOK_KEY=/path/to/privkey.pem
WEBHOOK_SECRET=
